{
  "name": "taskly",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:api": "npm run start:dev --workspace @taskly/api",
    "dev:web": "node scripts/dev-mobile.js web",
    "dev:emulator": "node scripts/dev-mobile.js emulator",
    "dev:local": "node scripts/dev-mobile.js local",
    "dev:tunnel": "node scripts/dev-mobile.js tunnel",
    "dev": "npm run dev:local",
    "start": "npm run db:up && npm run dev",
    "build:api": "npm run build --workspace @taskly/api",
    "lint:api": "npm run lint --workspace @taskly/api",
    "typecheck:mobile": "npm run typecheck --workspace @taskly/mobile",
    "db:up": "docker compose up -d --wait postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:migrate": "npm run db:migrate --workspace @taskly/api",
    "db:seed": "npm run db:seed --workspace @taskly/api",
    "db:setup": "npm run db:up && npm run db:migrate && npm run db:seed",
    "db:reset": "docker compose down -v && npm run db:setup"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
